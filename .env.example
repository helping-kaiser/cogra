# PostgreSQL
POSTGRES_USER=gnp
POSTGRES_PASSWORD=gnp_secret
POSTGRES_DB=gnp_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://gnp:gnp_secret@localhost:5432/gnp_db

# Memgraph (bolt protocol — no auth in community edition by default)
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687

# API
API_HOST=0.0.0.0
API_PORT=8080

# Genesis bootstrap (`make bootstrap`) — the instance's first User. Identity is
# supplied at run time (network.md §2); change the password before any real use.
GENESIS_USERNAME=genesis
GENESIS_EMAIL=genesis@cogra.local
GENESIS_PASSWORD=change-me-genesis

# Ed25519 JWT signing key (auth.md). Left blank here; `make bootstrap`
# generates one and appends it to your .env so access tokens survive restarts.
JWT_SIGNING_KEY=

# Logging: trace | debug | info | warn | error
RUST_LOG=debug
